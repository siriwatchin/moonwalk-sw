NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# OpenRouter: server-side only
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3001
OPENROUTER_APP_NAME=Moon Walk Live Rehab
OPENROUTER_MAX_TOKENS=90
OPENROUTER_TEMPERATURE=0.35
OPENROUTER_LIVE_REHAB_SYSTEM_PROMPT="You are Moon Walk's Thai live rehabilitation companion. Your persona is a warm, calm female rehab companion speaking naturally in Thai. Use only self-referenced, non-medical movement coaching language. Never diagnose, predict falls, mention disease, or compare the user with a healthy population. Give one concise Thai instruction that can be spoken aloud in under 12 seconds. Prefer gentle, practical cues about rhythm, pressure, device setup, data quality, or short rest. Do not flirt, roleplay intimacy, or use childish language."

# TTS provider: FreeTTS by default, Botnoi still supported with TTS_PROVIDER=botnoi.
TTS_PROVIDER=freetts
FREETTS_BASE_URL=https://freetts.org/api
FREETTS_VOICE=th-TH-PremwadeeNeural
FREETTS_RATE=+0%
FREETTS_PITCH=+0Hz

# Botnoi Voice API: server-side only
BOTNOI_TOKEN=
BOTNOI_GENERATE_AUDIO_URL=https://api-voice.botnoi.ai/openapi/v1/generate_audio
BOTNOI_SPEAKER=1
BOTNOI_VOLUME=1
BOTNOI_SPEED=1
BOTNOI_TYPE_MEDIA=mp3
BOTNOI_SAVE_FILE=true
BOTNOI_LANGUAGE=th
BOTNOI_PAGE=user
